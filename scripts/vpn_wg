#!/bin/bash

source /usr/local/LosChichos/conf/variables.conf
source $DIR/$PROJECTO/$DIR_CONF/$FUNC
source "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_CONF"

######################################################################
###  Funcions
######################################################################

fnc_iniciar() {
	if [[ $(fnc_estat_router) =~ ^$ACTIVADO ]]; then
		echo "VPN routers ja esta iniciada."
	else
		echo "Iniciant VPN routers"
		fnc_crear_config_routers
	fi

	if [[ $(fnc_estat_usuari) =~ ^$ACTIVADO ]]; then
		echo "VPN users ja esta iniciada."
	else
		echo "Iniciant VPN users"
		fnc_crear_config_usuaris
	fi
}

fnc_aturar() {
	
	
	if [[ $(fnc_estat_router) =~ ^$DESACTIVADO ]]; then
		echo "VPN routers no esta iniciada."
	else
		echo "Aturant VPN routers"
		wg-quick down $vpn_wg_int_router
	fi

	if [[ $(fnc_estat_usuari) =~ ^$DESACTIVADO ]]; then
		echo "VPN users no esta iniciada."
	else
		echo "Aturant VPN users"
		wg-quick down $vpn_wg_int_users
	fi
}

######################################################################
### vpn routers
######################################################################


fnc_crear_config_routers() {

	if [ -z $vpn_wg_routers_public_key ] || [ -z $vpn_wg_routers_private_key ]; then
		wg genkey | tee "$DIR/$PROJECTO/$DIR_TMP/privatekey" | wg pubkey | tee "$DIR/$PROJECTO/$DIR_TMP/publickey" > /dev/null
		PRIVATE_KEY=$(cat "$DIR/$PROJECTO/$DIR_TMP/privatekey")
		PUBLIC_KEY=$(cat "$DIR/$PROJECTO/$DIR_TMP/publickey")
		
		vpn_wg_routers_private_key=$(printf '%s\n' "$PRIVATE_KEY" | sed 's/[&/\]/\\&/g')
		vpn_wg_routers_public_key=$(printf '%s\n' "$PUBLIC_KEY" | sed 's/[&/\]/\\&/g')

		sed -i "s|^vpn_wg_routers_public_key=.*|vpn_wg_routers_public_key=$vpn_wg_routers_public_key|" "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_CONF"
		sed -i "s|^vpn_wg_routers_private_key=.*|vpn_wg_routers_private_key=$vpn_wg_routers_private_key|" "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_CONF"

	fi
	fitxer_conf="$vpn_wg_routers_fitxer_conf"

	(
		source $DIR/$PROJECTO/$DIR_CONF/$IFWAN_CONF
		echo "[Interface]"
		echo "Address = $vpn_wg_ip_router/$vpn_wg_ip_routers_mascara"
		echo "PrivateKey = $vpn_wg_routers_private_key"
		echo "ListenPort = $vpn_wg_port_router"	
		
	) > "$fitxer_conf"

	for LINIA in $(grep -v "^#" "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_ROUTERS")
	do
		ROUTER_IP_PUBLICA=$(echo "$LINIA" | cut -d ";" -f 1)
		ROUTER_IP_PRIVADA=$(echo "$LINIA" | cut -d ";" -f 2)
		ROUTER_PUBLIC_KEY=$(echo "$LINIA" | cut -d ";" -f 3)
		ROUTER_PRIVATE_KEY=$(echo "$LINIA" | cut -d ";" -f 4)
		ROUTER_RUTES=$(echo "$LINIA" | cut -d ";" -f 5)
		
		(					
			echo "[Peer]"
			echo "PublicKey = $ROUTER_PUBLIC_KEY"
			echo "Endpoint = $ROUTER_IP_PUBLICA:$vpn_wg_port_router"
			echo "AllowedIPs = $ROUTER_IP_PRIVADA/$vpn_wg_ip_routers_mascara,$ROUTER_RUTES"
			echo "PersistentKeepalive = 25"
		) >> "$fitxer_conf"

	done

	wg-quick up $vpn_wg_int_router
}

fnc_afegir_router() {
	ROUTER_IP_PUBLICA=$1
	RUTES=$2

	if ! fnc_validar_ip "$ROUTER_IP_PUBLICA"; then
		echo "No es una IP valida."
		exit 1
	fi

	if grep -q "$ROUTER_IP_PUBLICA;" "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_ROUTERS"; then
		echo "Ja existeix l'IP de router."
		exit 1
	fi

	wg genkey | tee "$DIR/$PROJECTO/$DIR_TMP/privatekey" | wg pubkey | tee "$DIR/$PROJECTO/$DIR_TMP/publickey" > /dev/null
	PRIVATE_KEY=$(cat "$DIR/$PROJECTO/$DIR_TMP/privatekey")
	PUBLIC_KEY=$(cat "$DIR/$PROJECTO/$DIR_TMP/publickey")
	
	IP_LLIURE=$(fnc_busca_ip_lliure "$vpn_wg_ip_router" "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_ROUTERS")
	if [ -z "${IP_LLIURE}" ]; then
		echo "No hi ha IPs lliures."
		exit 1
	fi

	echo "$ROUTER_IP_PUBLICA;$IP_LLIURE;$PUBLIC_KEY;$PRIVATE_KEY;$RUTES" >> "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_ROUTERS"

}

fnc_eliminar_router() {
	
	IP_ROUTER_PUBLICA=$1
	if [ -z "$IP_ROUTER_PUBLICA" ]; then
		echo "No hi ha IP de router."
		exit 1
	fi

	if ! grep -q "$IP_ROUTER_PUBLICA;" "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_ROUTERS"; then
		echo "No existeix l'IP de router."
		exit 1
	fi

	sed -i "/$IP_ROUTER_PUBLICA;/d" "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_ROUTERS"
}

fnc_mostrar_config_router() {

	IP_ROUTER_PUBLICA=$1

	if [ -z "$IP_ROUTER_PUBLICA" ]; then
		echo "No hi ha IP de router."
		exit 1
	fi

	if ! grep -q "$IP_ROUTER_PUBLICA;" "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_ROUTERS"; then
		echo "No existeix l'IP de router."
		exit 1
	fi	
	
	for linia in $(grep "$IP_ROUTER_PUBLICA;" "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_ROUTERS"); do
		ROUTER_IP_PUBLICA=$(echo "$linia" | cut -d ";" -f 1)
		ROUTER_IP_PRIVADA=$(echo "$linia" | cut -d ";" -f 2)
		ROUTER_PUBLIC_KEY=$(echo "$linia" | cut -d ";" -f 3)
		ROUTER_PRIVATE_KEY=$(echo "$linia" | cut -d ";" -f 4)
		IFWAN=$(ip route show default | awk '/default/ {print $5}')
		IP_ROUTER_A=$(ip -o -4 addr show dev $IFWAN | awk '{print $4}' | cut -d/ -f1)

		echo "[Interface]"
		echo "Address = $ROUTER_IP_PRIVADA/$vpn_wg_ip_routers_mascara"
		echo "PrivateKey = $ROUTER_PRIVATE_KEY"
		echo "ListenPort = $vpn_wg_port_router"	
		
		echo "[Peer]"
		echo "PublicKey = $vpn_wg_routers_public_key"
		echo "Endpoint = $IP_ROUTER_A:$vpn_wg_port_router"
		echo "AllowedIPs = $vpn_wg_ip_router/$vpn_wg_ip_routers_mascara,$vpn_wg_routers_allowed_ips"
		echo "PersistentKeepalive = 25"
	done	
}

######################################################################
### vpn users
######################################################################

fnc_crear_config_usuaris() {

	if [ -z $vpn_wg_users_public_key ] || [ -z $vpn_wg_users_private_key ]; then
		wg genkey | tee "$DIR/$PROJECTO/$DIR_TMP/privatekey" | wg pubkey | tee "$DIR/$PROJECTO/$DIR_TMP/publickey" > /dev/null
		PRIVATE_KEY=$(cat "$DIR/$PROJECTO/$DIR_TMP/privatekey")
		PUBLIC_KEY=$(cat "$DIR/$PROJECTO/$DIR_TMP/publickey")
		echo "Creant claus per users"
		
		vpn_wg_users_private_key=$(printf '%s\n' "$PRIVATE_KEY" | sed 's/[&/\]/\\&/g')
		vpn_wg_users_public_key=$(printf '%s\n' "$PUBLIC_KEY" | sed 's/[&/\]/\\&/g')

		sed -i "s|^vpn_wg_users_public_key=.*|vpn_wg_users_public_key=$vpn_wg_users_public_key|" "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_CONF"
		sed -i "s|^vpn_wg_users_private_key=.*|vpn_wg_users_private_key=$vpn_wg_users_private_key|" "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_CONF"
	fi

	fitxer_conf="$vpn_wg_users_fitxer_conf"
	(
		source $DIR/$PROJECTO/$DIR_CONF/$IFWAN_CONF
		echo "[Interface]"
		echo "Address = $vpn_wg_ip_users/$vpn_wg_ip_users_mascara"
		echo "PrivateKey = $vpn_wg_users_private_key"
		echo "ListenPort = $vpn_wg_port_users"	
		 
	) > "$fitxer_conf"

	for LINIA in $(grep -v "^#" "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_USUARIS")
	do
		NOM_USUARI=$(echo "$LINIA" | cut -d ";" -f 1)
		USUARI_IP_PRIVADA=$(echo "$LINIA" | cut -d ";" -f 2)
		USUARI_PUBLIC_KEY=$(echo "$LINIA" | cut -d ";" -f 3)		
		(	
			echo "# $NOM_USUARI"
			echo "[Peer]"
			echo "PublicKey = $USUARI_PUBLIC_KEY"
			echo "AllowedIPs = $USUARI_IP_PRIVADA/32"			
		) >> "$fitxer_conf"
	done

	wg-quick up $vpn_wg_int_users
}

fnc_afegir_usuari() {
	NOM_USUARI=$1

	if ! fnc_nom_alfanumeric "$NOM_USUARI"; then
		echo "No es un nom valid."
		exit 1
	fi

	if grep -q "$NOM_USUARI;" "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_USUARIS"; then
		echo "Ja existeix l'usuari $NOM_USUARI."
		exit 1
	fi

	wg genkey | tee "$DIR/$PROJECTO/$DIR_TMP/privatekey" | wg pubkey | tee "$DIR/$PROJECTO/$DIR_TMP/publickey" > /dev/null
	PRIVATE_KEY=$(cat "$DIR/$PROJECTO/$DIR_TMP/privatekey")
	PUBLIC_KEY=$(cat "$DIR/$PROJECTO/$DIR_TMP/publickey")
	
	IP_LLIURE=$(fnc_busca_ip_lliure "$vpn_wg_ip_users" "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_USUARIS")
	if [ -z "${IP_LLIURE}" ]; then
		echo "No hi ha IPs lliures."
		exit 1
	fi

	echo "$NOM_USUARI;$IP_LLIURE;$PUBLIC_KEY;$PRIVATE_KEY" >> "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_USUARIS"
	echo "Usuari afegit: $NOM_USUARI $IP_LLIURE $PUBLIC_KEY $PRIVATE_KEY"
}

fnc_eliminar_usuari() {

	NOM_USUARI=$1
	if [ -z "$NOM_USUARI" ]; then
		echo "No hi ha IP d'usuari."
		exit 1
	fi

	if ! grep -q "$NOM_USUARI;" "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_USUARIS"; then
		echo "No existeix l'IP d'usuari."
		exit 1
	fi

	sed -i "/$NOM_USUARI;/d" "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_USUARIS"
}

fnc_mostrar_config_usuari() {
	
	NOM_USUARI=$1
	WAN_IF=$(ip route show default | awk '/default/ {print $5}')

	if ! fnc_nom_alfanumeric "$NOM_USUARI"; then
		echo "No es un nom valid."
		exit 1
	fi

	if ! grep -q "$NOM_USUARI;" "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_USUARIS"; then
		echo "No existeix l'usuari $NOM_USUARI."
		exit 1
	fi	
	
	for linia in $(grep "$NOM_USUARI;" "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_USUARIS"); do
		NOM_USUARI=$(echo "$linia" | cut -d ";" -f 1)
		USUARI_IP_PRIVADA=$(echo "$linia" | cut -d ";" -f 2)
		USUARI_PUBLIC_KEY=$(echo "$linia" | cut -d ";" -f 3)
		USUARI_PRIVATE_KEY=$(echo "$linia" | cut -d ";" -f 4)
		source "$DIR/$PROJECTO/$DIR_CONF/$IFWAN_CONF"
		IP_ROUTER_A=$(ip -o -4 addr show dev $WAN_IF | awk '{print $4}' | cut -d/ -f1)

		echo "[Interface]"
		echo "Address = $USUARI_IP_PRIVADA/$vpn_wg_ip_users_mascara"
		echo "PrivateKey = $USUARI_PRIVATE_KEY"
		echo "ListenPort = $vpn_wg_port_users"	
		 
		echo "[Peer]"
		echo "PublicKey = $vpn_wg_users_public_key"
		echo "Endpoint = $IP_ROUTER_A:$vpn_wg_port_users"
		echo "AllowedIPs = $vpn_wg_ip_users/$vpn_wg_ip_users_mascara,$vpn_wg_routers_allowed_ips"
		echo "PersistentKeepalive = 25"
	done
}

fnc_busca_ip_lliure() {
	IP_LLIURE=""
	IP_BASE="${1%.*}."
	IP_FITXER=$2
	for i in $(seq 2 254); do
		IP="${IP_BASE}${i}"
		if ! grep -q "${IP};" "$IP_FITXER"; then
			IP_LLIURE="${IP}"
			echo "$IP_LLIURE"
			break
		fi
	done

	if [ -z "${IP_LLIURE}" ]; then
		echo ""
		exit 1
	fi
}

fnc_llista_routers() {
	cat "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_ROUTERS" | grep -v '^#'
}

fnc_llista_usuaris() {
	cat "$DIR/$PROJECTO/$DIR_CONF/$VPN_WG_USUARIS" | grep -v "^#"
}

#######################################################################

fnc_configurar() {
	OPCIO_1=$1
	shift	

	case "$OPCIO_1" in
		afegir_router)
			fnc_afegir_router $@	
			;;
		eliminar_router)
			fnc_eliminar_router $@
			;;
		afegir_usuari)
			fnc_afegir_usuari $@		
			;;
		eliminar_usuari)
			fnc_eliminar_usuari $@
			;;
		*)
			echo "Error falta [afegir_router, eliminar_router, afegir_usuari, eliminar_usuari]"
			;;
	esac
	
}

fnc_mostrar() {
	OPCIO_1=$1
	shift	

	case "$OPCIO_1" in
		llista_routers)
			fnc_llista_routers $@
			;;
		config_router)
			fnc_mostrar_config_router $@
			;;
		config_int_router)
			cat $vpn_wg_routers_fitxer_conf
			;;
		llista_usuaris)
			fnc_llista_usuaris $@
			;;
		config_usuari)
			fnc_mostrar_config_usuari $@
			;;
		config_int_usuari)
			cat $vpn_wg_users_fitxer_conf
			;;
		*)
			echo "Error falta [llista_routers, config_router, config_int_router, llista_usuaris, config_usuari,config_int_usuari]"
			;;
		esac
}

fnc_estat() {

	OPCIO_1=$1
	shift	
	case "$OPCIO_1" in
		"" | "tot")
			fnc_estat_router
			echo ""
			fnc_estat_usuari
			;;
		router)
			fnc_estat_router
			;;
		users)
			fnc_estat_usuari
			;;
		*)
			echo "Error falta [router, users]"
			;;
	esac	
}

fnc_estat_router() {
	if ip a l | grep "$vpn_wg_int_router" | grep -q "UP"; then
		echo "$ACTIVADO  vpn routers"
		echo ""
		ip a l dev $vpn_wg_int_router
	else
		echo "$DESACTIVADO  vpn routers"
	fi
}

fnc_estat_usuari() {
	if ip a l | grep "$vpn_wg_int_users" | grep -q "UP"; then
		echo "$ACTIVADO  vpn users"
		echo ""
		ip a l dev $vpn_wg_int_users
	else
		echo "$DESACTIVADO  vpn users"
	fi
}

######################################################################
###  MAIN
######################################################################

MSG="falta [iniciar, aturar, configurar ,estat]"

# Comprovem que hi hagi almenys un argument (la opció)
if [ $# -lt 1 ]; then
	echo "$MSG"
	exit 1
fi

OPCIO_1=$1
shift

# Fem switch per executar la funció que toca
case "$OPCIO_1" in
iniciar)
	fnc_iniciar $@
	;;
aturar)
	fnc_aturar $@
	;;
configurar)
	fnc_configurar $@
	;;
mostrar)
	fnc_mostrar $@
	;;
estat)
	fnc_estat $@
	;;
*)
	echo "$MSG"
	;;
esac
