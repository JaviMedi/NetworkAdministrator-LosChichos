#!/bin/bash

###########################
## Script de Instalación ##
###########################

ORIGEN="../"
DESTINO="/usr/local"
NOMBRE_CARPETA="LosChichos"
DESTINO_FINAL="$DESTINO/$NOMBRE_CARPETA"
DIR_SYSTEM="system"
SERVICE="loschichos.socket"
SERVICE_UNIT="loschichos@.service"
IP_ADDR="127.0.0.1"
PORT="1234"


if [[ "$EUID" -ne 0 ]]; then
	echo "Yeeeee, ejecuta esto como root anda..." >&2
	exit 1
fi

fnc_ajustar_permisos() {
    echo "1. Ajustando permisos en $DESTINO_FINAL..."
    
    # Check if directory exists before applying permissions
    if [ ! -d "$DESTINO_FINAL" ]; then
        echo "Error: El directorio $DESTINO_FINAL no existe. Ejecuta el modo 2 (Copiar Ficheros) primero."
        return 1
    fi
    
    # Permisos generales: root:root en todo
    chown -R root:root "$DESTINO_FINAL"
    find "$DESTINO_FINAL" -type d -exec chmod 755 {} \;
    find "$DESTINO_FINAL" -type f -exec chmod 644 {} \;
    
    # Permisos de ejecución para scripts y cgi
    chmod +x "$DESTINO_FINAL/cgi-bin/"*
    chmod +x "$DESTINO_FINAL/scripts/"*
    chmod +x "$DESTINO_FINAL/install/install"
    chmod +x "$DESTINO_FINAL/system/"*
    
    # Carpeta seguro: root:www-data con permisos restringidos
    # www-data necesita poder leer usuarios.db y escribir/leer en sessions/
    if [ -d "$DESTINO_FINAL/seguro" ]; then
        chown -R root:www-data "$DESTINO_FINAL/seguro"
        # El directorio seguro: root puede todo, www-data puede listar y entrar (r-x)
        chmod 750 "$DESTINO_FINAL/seguro"
        # usuarios.db: solo root escribe, www-data puede leer (para autenticar logins)
        if [ -f "$DESTINO_FINAL/seguro/usuarios.db" ]; then
            chmod 640 "$DESTINO_FINAL/seguro/usuarios.db"
        fi
        # sessions/: www-data debe poder crear/leer/borrar sus propios ficheros de sesión
        if [ -d "$DESTINO_FINAL/seguro/sessions" ]; then
            chmod 770 "$DESTINO_FINAL/seguro/sessions"
        fi
    fi

    echo "Configurando sudoers..."
    ## EDITAR VISUDO PARA EL SCRIPT TALLAFOCS
    USUARIO="www-data"
    SUDO_FILE="/etc/sudoers.d/${USUARIO}-iptables"
    REGLA="${USUARIO} ALL=(ALL) NOPASSWD: /usr/sbin/iptables"

    if ! id "$USUARIO" &>/dev/null; then
        echo "Advertencia: El usuario $USUARIO no existe"
    else
        echo "$REGLA" > "$SUDO_FILE"
        chmod 440 "$SUDO_FILE"

        if visudo -cf "$SUDO_FILE" >/dev/null 2>&1; then
            echo "$USUARIO puede usar iptables sin contraseña"
        else
            echo "ERROR en sintaxis sudoers, no se aplica"
            rm -f "$SUDO_FILE"
        fi
    fi

    echo "Permisos ajustados correctamente."
}

fnc_crear_usuario() {
    echo "Crear usuario administrador para el login web..."

    SECURE_DIR="$DESTINO_FINAL/seguro"
    USER_DB="$SECURE_DIR/usuarios.db"
    SESSION_DIR="$SECURE_DIR/sessions"

    # Crear estructura de seguro si no existe
    if [ ! -d "$SECURE_DIR" ]; then
        mkdir -p "$SECURE_DIR"
        chown root:www-data "$SECURE_DIR"
        chmod 750 "$SECURE_DIR"
    fi

    if [ ! -d "$SESSION_DIR" ]; then
        mkdir -p "$SESSION_DIR"
        chown root:www-data "$SESSION_DIR"
        chmod 770 "$SESSION_DIR"
    fi

    # Solicitar nombre de usuario
    read -rp "Nombre de usuario: " NEW_USER
    if [ -z "$NEW_USER" ]; then
        echo "Error: el nombre de usuario no puede estar vacío."
        return 1
    fi

    # Solicitar contraseña (sin eco)
    read -rsp "Contraseña: " NEW_PASS
    echo
    if [ -z "$NEW_PASS" ]; then
        echo "Error: la contraseña no puede estar vacía."
        return 1
    fi

    # Generar hash SHA-512 con salt aleatorio
    HASH=$(openssl passwd -6 "$NEW_PASS")

    # Agregar usuario al db (o crearlo si no existe)
    if [ ! -f "$USER_DB" ]; then
        touch "$USER_DB"
        chown root:www-data "$USER_DB"
        chmod 640 "$USER_DB"
    fi

    # Comprueba si el usuario ya existe
    if grep -q "^${NEW_USER}:" "$USER_DB"; then
        # Actualiza el hash existente
        sed -i "s|^${NEW_USER}:.*|${NEW_USER}:${HASH}|" "$USER_DB"
        echo "Usuario '$NEW_USER' actualizado correctamente."
    else
        echo "${NEW_USER}:${HASH}" >> "$USER_DB"
        echo "Usuario '$NEW_USER' creado correctamente."
    fi
}

fnc_copia_ficheros() {
    echo "2. Copiando ficheros a $DESTINO_FINAL..."

    if [ ! -d "$DESTINO_FINAL" ]; then
        mkdir -p "$DESTINO_FINAL"
    fi

    cp -r "$ORIGEN"* "$DESTINO_FINAL"/
    
    echo "Copia completada."
}

fnc_instalar_dependencias() {
    echo "3. Instalando dependencias..."
    
    apt-get update
    apt-get install -y curl net-tools dnsmasq hostapd apache2 expect socat iw dbus-x11 aha wireguard
    
    echo "Dependencias instaladas."
}


fnc_configurar_https() {
    echo "Configurando HTTPS..."

    DOMAIN="127.0.0.1"
    SSL_CERT="/etc/ssl/certs/loschichos-selfsigned.crt"
    SSL_KEY="/etc/ssl/private/loschichos-selfsigned.key"

    # Activar módulos necesarios
    a2enmod ssl headers rewrite cgi

    # Generar certificado si no existe
    if [ ! -f "$SSL_CERT" ]; then
        echo "Generando certificado SSL..."
        openssl req -x509 -nodes -days 365 \
            -newkey rsa:2048 \
            -keyout "$SSL_KEY" \
            -out "$SSL_CERT" \
            -subj "/CN=$DOMAIN"
    fi

    # Configurar HTTP → HTTPS
    cat > /etc/apache2/sites-available/000-default.conf <<EOF
<VirtualHost *:80>
    ServerName $DOMAIN
    Redirect permanent / https://$DOMAIN/
</VirtualHost>
EOF

    # Configurar VirtualHost HTTPS
    cat > /etc/apache2/sites-available/loschichos-ssl.conf <<EOF
<VirtualHost *:443>
    ServerName $DOMAIN

    SSLEngine on
    SSLCertificateFile $SSL_CERT
    SSLCertificateKeyFile $SSL_KEY

    ScriptAlias /cgi-bin/ /usr/local/LosChichos/cgi-bin/

    RedirectMatch ^/$ /cgi-bin/main.cgi

    <Directory "/usr/local/LosChichos/cgi-bin">
        AllowOverride None
        Options +ExecCGI -MultiViews +SymLinksIfOwnerMatch
        Require all granted
        AddHandler cgi-script .cgi
    </Directory>

    # Cabeceras de seguridad
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
</VirtualHost>
EOF

    a2ensite loschichos-ssl
    systemctl reload apache2

    echo "HTTPS configurado correctamente."
} 


fnc_instalacion_completa() {
    echo "4. Instalación completa..."
    
    fnc_instalar_dependencias
    fnc_copia_ficheros
    fnc_ajustar_permisos
    
    fnc_configurar_https

    ## Configuración de CGI
    echo "Configurando CGI..."
    cat > /etc/apache2/conf-available/loschichos-cgi.conf <<'EOF'
ScriptAlias /cgi-bin/ /usr/local/LosChichos/cgi-bin/

<Directory "/usr/local/LosChichos/cgi-bin">
    AllowOverride None
    Options +ExecCGI -MultiViews +SymLinksIfOwnerMatch
    Require all granted
    AddHandler cgi-script .cgi
</Directory>
EOF

    a2enconf loschichos-cgi
    
    # Desactivar deflate para CGI streams instántaneos (evitar buffering)
    a2dismod -f deflate
    systemctl restart apache2

    ## Desactivar NetworkManager
    echo "Desactivando NetworkManager..."
    systemctl stop NetworkManager
    systemctl disable NetworkManager
    echo "NetworkManager desactivado."

    ## Instalando el servicio socket
    echo "Instalando servicio LosChichos..."

    cat > /etc/systemd/system/loschichos.socket <<EOF
[Unit]
Description=LosChichos TCP socket

[Socket]
ListenStream=${IP_ADDR}:${PORT}
Accept=yes
MaxConnections=20

[Install]
WantedBy=sockets.target
EOF

    cat > /etc/systemd/system/loschichos@.service <<EOF
[Unit]
Description=LosChichos session

[Service]
ExecStart=${DESTINO_FINAL}/${DIR_SYSTEM}/scr_cli
StandardInput=socket
StandardOutput=socket
StandardError=socket
KillMode=process
TimeoutStopSec=5
EOF

    systemctl daemon-reexec
    systemctl daemon-reload
    systemctl enable --now loschichos.socket

    echo "Servicio instalado y escuchando en $IP_ADDR:$PORT"

    ## Crear usuario administrador
    echo ""
    echo "=================================================================="
    echo "PASO FINAL: Crear usuario administrador para el login web"
    echo "=================================================================="
    fnc_crear_usuario

    echo "Instalación completa terminada."
}


################################################################################
### MAIN
################################################################################


case "$1" in
  permisos | 1)
    fnc_ajustar_permisos
    ;;
  copiar | 2)
    fnc_copia_ficheros
    ;;
  dependencias | 3)
    fnc_instalar_dependencias
    ;;
  completa | 4 | install | -y)
    fnc_instalacion_completa
    ;;
  adduser | usuario)
    fnc_crear_usuario
    ;;
  start)
    systemctl start $SERVICE
    ;;
  stop)
    systemctl stop $SERVICE
    ;;
  restart)
    systemctl restart $SERVICE
    ;;
  installhttps)
    fnc_configurar_https
    ;;
  status)
    systemctl status $SERVICE
    ;;
  uninstall)
    echo "Desinstalando servicio LosChichos..."
    systemctl disable --now $SERVICE
    rm -f /etc/systemd/system/loschichos.socket
    rm -f /etc/systemd/system/loschichos@.service
    systemctl daemon-reexec
    systemctl daemon-reload
    echo "Servicio desinstalado."
    ;;
  *)
    echo "Uso: install {1(permisos) | 2(copiar) | 3(dependencias) | 4(completa) | adduser | start | stop | restart | status | uninstall}"
    echo " - 1 o permisos: Ajustar permisos"
    echo " - 2 o copiar: Copiar ficheros a /usr/local/LosChichos"
    echo " - 3 o dependencias: Instalar dependencias del sistema"
    echo " - 4 o completa: Ejecutar instalación completa"
    echo " - adduser: Crear o actualizar usuario administrador web"
    echo " - start: Iniciar servicio"
    echo " - stop: Detener servicio"
    echo " - restart: Reiniciar servicio"
    echo " - status: Estado del servicio"
    echo " - uninstall: Desinstalar servicio"
    ;;
esac